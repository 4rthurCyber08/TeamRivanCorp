Set Switchports to L3  "PORT1 MUST BE PART OF LAN"  = VLAN1
config system virtual-switch
 edit lan
  config port
   delete port2


config system interface
 edit wan1
  set mode static
  set ip 200.0.0.72 255.255.255.0 
  set allowaccess ping https ssh telnet
  set role wan
  set alias "INTERNET"
  next
 edit lan
  set mode static
  set ip 10.72.72.254 255.255.255.128 
  set allowaccess ping https ssh telnet http
  set role lan
  set alias "INTERNAL"
  end
config router ospf 
 set router-id 10.72.72.254
 set log-neighbor-changes enable
 config area
  edit 0.0.0.0
   next
 config network
  edit 1
   set area 0.0.0.0
   set prefix 10.72.72.128/25
  edit 2
   set area 0.0.0.0
   set prefix 200.0.0.0/24
   





















