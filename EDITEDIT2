****************
ZONE-BASED FW POLICY

!@UTM-PH
conf t
 zone security OUTSIDE
  desc PUBLIC-FACING
 zone security INSIDE
  desc PRIVATE-NETWORK
 int g1
  zone-member security OUTSIDE
 int g3
  zone-member security INSIDE
 !
 ip access-list extended TRAFFIC-OUT-TO-IN
  permit ip any any
 ip access-list extended TRAFFIC-IN-TO-OUT
  permit ip any any
 !
 class-map type inspect match-any CM-OUT-TO-IN
  match access-group name TRAFFIC-OUT-TO-IN
 class-map type inspect match-any CM-IN-TO-OUT
  match access-group name TRAFFIC-IN-TO-OUT
 !
 policy-map type inspect PM-OUT-TO-IN
  class type inspect CM-OUT-TO-IN
   drop log
  class class-default
   drop log
 policy-map type inspect PM-IN-TO-OUT
  class type inspect CM-IN-TO-OUT
   inspect
  class class-default
   drop log
 !
 zone-pair security ZP-OUT-TO-IN source OUTSIDE destination INSIDE
  service-policy type inspect PM-OUT-TO-IN
 zone-pair security ZP-IN-TO-OUT source INSIDE destination OUTSIDE
  service-policy type inspect PM-IN-TO-OUT
  end



****************
Place BLDG-1 & BLDG-2 in DMZ and allow only SSH for BLDG-JP


!@UTM-PH
conf t
 zone security DMZ
  desc SECURE-PUBLIC-SERVERS
 int g3
  zone-member security DMZ
 !
 ip access-list extended TRAFFIC-DMZ-TO-OUT
  permit ip any any
 no  ip access-list extended TRAFFIC-SSH-OUT-TO-DMZ
 ip access-list extended TRAFFIC-SSH-OUT-TO-DMZ
  permit tcp host 208.8.8.102 host 11.11.11.101 eq 22
 !
 class-map type inspect match-any CM-SSH
  match protocol SSH
 class-map type inspect match-all CM-SSH-OUT-TO-DMZ
  match class CM-SSH
  match access-group name TRAFFIC-SSH-OUT-TO-DMZ
 class-map type inspect match-any CM-DMZ-TO-OUT
  match access-group name TRAFFIC-DMZ-TO-OUT
 !
 policy-map type inspect PM-DMZ-TO-OUT
  class type inspect CM-DMZ-TO-OUT
   inspect
  class class-default
   drop log
 policy-map type inspect PM-OUT-TO-DMZ
  class type inspect CM-SSH-OUT-TO-DMZ
   inspect
  class class-default
   drop log
 !
 zone-pair security ZP-DMZ-TO-OUT source DMZ destination OUTSIDE
  service-policy type inspect PM-DMZ-TO-OUT
 zone-pair security ZP-OUT-TO-DMZ source OUTSIDE destination DMZ
  service-policy type inspect PM-OUT-TO-DMZ
  end



