## ZONE-BASED FIREWALL

### STEP 1 - DEFINE & ASSIGN ZONES

!@UTM-US,UTM-PH,UTM-JP
conf t
 zone security INSIDE
 zone security OUTSIDE
 zone security DMZ
 !
 interface g1
  zone-member security OUTSIDE
 interface g3
  zone-member security INSIDE
 interface tunnel1
  zone-member security OUTSIDE
  end


### STEP 2 - MATCH TRAFFIC (ACL)

!@UTM-US,UTM-PH,UTM-JP
conf t
 ip access-list extended ACL-ALL-TRAFFIC
  permit ip any any
  end

### STEP 3 - CLASSIFY TRAFFIC

!@UTM-US,UTM-PH,UTM-JP
conf t
 class-map type inspect match-any CM-ALL-TRAFFIC
  match access-group name ACL-ALL-TRAFFIC
  end


### STEP 4 - SPECIFY WHAT TO DO WITH THE TRAFFIC

!@UTM-US,UTM-PH,UTM-JP
conf t
 policy-map type inspect PM-IN-TO-OUT
  class type inspect CM-ALL-TRAFFIC
   inspect
  class class-default 
   drop log
 !
 policy-map type inspect PM-OUT-TO-IN
  class type inspect CM-ALL-TRAFFIC
   drop log
  class class-default
   drop log
   end


### STEP 5 - ASSIGN ZONE-PAIRS FOR DIRECTIONAL TRAFFIC

!@UTM-US,UTM-PH,UTM-JP
conf t
 zone-pair security ZP-IN-TO-OUT source INSIDE destination OUTSIDE
  service-policy type inspect PM-IN-TO-OUT
 zone-pair security ZP-OUT-TO-IN source OUTSIDE destination INSIDE
  service-policy type inspect PM-OUT-TO-IN
  end




### STEP 6 - SETUP DMZ

!@UTM-PH
conf t
 interface g3
  zone-member security DMZ
 interface tunnel1
  zone-member security OUTSIDE
 !
 ip access-list extended ACL-SSH-ACCESS
  permit tcp host 208.8.8.12 host 10.11.11.101 eq 22
 !
 class-map type inspect match-all CM-SSH-ACCESS
  match access-group name ACL-SSH-ACCESS
  match protocol ssh
 !
 policy-map type inspect PM-DMZ-TO-OUT
  class type inspect CM-ALL-TRAFFIC
   inspect
  class class-default
   drop log
 !
 policy-map type inspect PM-OUT-TO-DMZ
  class type inspect CM-SSH-ACCESS
   inspect
  class type inspect CM-ALL-TRAFFIC
   drop log
  class class-default
   drop log
 !
 zone-pair security ZP-DMZ-TO-OUT source DMZ destination OUTSIDE
  service-policy type inspect PM-DMZ-TO-OUT
 zone-pair security ZP-OUT-TO-DMZ source OUTSIDE destination DMZ
  service-policy type inspect PM-OUT-TO-DMZ
  end
