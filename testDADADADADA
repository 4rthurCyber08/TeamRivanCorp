# DMVPN Configuration

## PHASE 1 - Internet Key Exchange

:HUB:

!@UTM-US
conf t
 crypto ikev2 proposal PROPOSAL-1
  encryption aes-cbc-256
  integrity sha256
  group 14
 !
 crypto ikev2 proposal PROPOSAL-2
  encryption aes-gcm-256
  prf sha256
  group 14
 !
 crypto ikev2 policy POLICY-1
  proposal PROPOSAL-1 
  proposal PROPOSAL-2
 !
 crypto ikev2 keyring KEY-1
  peer SPOKES
   address 0.0.0.0 0.0.0.0
   pre-shared-key C1sc0123
 !
 crypto ikev2 profile PROFILE-1
  match identity remote address 0.0.0.0 0.0.0.0
  authentication local pre-share
  authentication remote pre-share
  keyring local KEY-1
  end

 
