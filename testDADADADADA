## PHASE 2 - INTERNET PROTOCOL SECURITY

:HUB:

!@UTM-US
conf t
 crypto ipsec transform-set TS1 esp-256-aes esp-sha256-hmac
  mode tunnel
 !
 crypto ipsec transform-set TS2 esp-gcm 256
  mode tunnel
 !
 crypto ipsec profile IPSEC-PROFILE-1
  set transform-set TS1 TS2
  set pfs group14
  set ikev2-profile PROFILE-1
 !
 interface tunnel 1
  ip add 172.16.1.254 255.255.255.0
  tunnel source g1
  tunnel protection ipsec profile IPSEC-PROFILE-1
  tunnel mode gre multipoint
  ip nhrp network-id 1337
  ip nhrp authentication C1sc0123
  ip nhrp map multicast dynamic
  ip nhrp redirect
  end
 

