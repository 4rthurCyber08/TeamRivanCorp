## Setup ZBF on RSTHAYUP R3

~~~
!@R3
conf t
 zone security OUTSIDE
 zone security INSIDE
 !
 int e1/2
  zone-member security INSIDE
 int e1/1
  zone-member security OUTSIDE
 !
 ip access-list extended MATCH-INOUT
  permit ip any any
 ip access-list extended MATCH-OUTIN
  permit ip any any
 !
 class-map type inspect match-any CM-INOUT
  match access-group name MATCH-INOUT
 class-map type inspect match-any  CM-OUTIN
  match access-group name MATCH-OUTIN
 !
 policy-map type inspect PM-INOUT
  class type inspect CM-INOUT
   inspect
  class class-default
   drop
 policy-map type inspect PM-OUTIN
  class type inspect CM-OUTIN
   drop
  class class-default
   drop
 !
 zone-pair security ZP-INOUT source INSIDE dest OUTSIDE
  service-policy type inspect PM-INOUT
 zone-pair security ZP-OUTIN source OUTSIDE dest INSIDE
  service-policy type inspect PM-OUTIN
  end
sh policy-map type inspect zone-pair 
~~~



